# ==========================================
# BASTISTIL Inventory - Environment Variables
# ==========================================
# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local

# ------------------------------------------
# Database (MySQL)
# ------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=bmm_db

# ------------------------------------------
# Authentication
# ------------------------------------------
# Must be at least 32 characters long
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-32-char-minimum-secret-key

# ------------------------------------------
# Server
# ------------------------------------------
# Defaults are production-ready. Override to 'development' / 'false' for local dev.
NODE_ENV=production
SESSION_COOKIE_SECURE=true

# NOTE: For LAN access without HTTPS, set SESSION_COOKIE_SECURE=false
# Otherwise, users will not be able to log in.

# ------------------------------------------
# Optional: Upstash Redis (Rate Limiting)
# ------------------------------------------
# If not set, in-memory rate limiting is used
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
