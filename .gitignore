# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temp/build artifacts
/build_errors.txt
/build_output.txt
/lint_output.txt
/start.err
/start.log
/temp_migration.sql
/inventory-app.tar
/transfer-package/
/test-results/
/backups/
import_subset.sql

# IDE / AI tools
.qwen/

# Large SQL backups
sql/03_31_2026 Backup.sql
sql/03_31_26.sql

# E2E auth state (regenerated by global-setup)
e2e/.auth/

# Runtime logs
next-dev.log
proxy.log
tunnel.log

# Local SSL certs (generated per-machine by mkcert or gen-cert.js)
/certs/
/cert/

# Test/scratch images
scanner.png
test.png

# Playwright MCP internal
.playwright-mcp/
